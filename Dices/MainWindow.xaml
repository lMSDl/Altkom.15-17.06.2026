<Window x:Class="Dices.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:controls="clr-namespace:Dices.Controls"
        xmlns:converters="clr-namespace:Dices.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Dices"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Dices.Properties"
        xmlns:vm="clr-namespace:Dices.ViewModels"
        Title="MainWindow"
        x:Name="root"
        Width="800"
        Height="450"
        mc:Ignorable="d">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction Command="{Binding OnLoadedCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>
    
    <!--<Window.Resources>
        <ResourceDictionary>
            <converters:DiceValueToImageSourceConverter x:Key="DiceValueToImageSourceConverter" />
        </ResourceDictionary>
    </Window.Resources>-->
    <DockPanel>
        <Button Width="32"
                Command="{Binding RemoveCommand}"
                Content="-"
                DockPanel.Dock="Left"
                FontSize="32" />
        <Button Width="32"
                Command="{Binding AddCommand}"
                Content="+"
                DockPanel.Dock="Right"
                FontSize="32" />
        <Button x:Name="RollButton"
                Command="{Binding RollCommand}"
                Content="{x:Static properties:Resources.Roll}"
                DockPanel.Dock="Bottom"
                FontSize="32" />

        <Label HorizontalContentAlignment="Center"
               Content="{Binding Sum}"
               DockPanel.Dock="Top"
               FontSize="32" />

        <ItemsControl Padding="5"
                      ItemsSource="{Binding Dices}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Background="Transparent"
                            Command="{Binding ElementName=root, Path=DataContext.DiceClickCommand}"
                            CommandParameter="{Binding}">

                        <controls:DiceControl />
                        <!--<Image Source="{Binding Value, Converter={StaticResource DiceValueToImageSourceConverter}}"
                        <Image Source="{Binding Value, Converter={converters:DiceValueToImageSourceConverter}}"/>-->
                    </Button>
                    <!--<controls:DiceButtonControl Background="Transparent"
                                                Click="Dice_Click"
                                                IsBlocked="{Binding IsLocked}"
                                                Number="{Binding Value}" />-->
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>
</Window>
