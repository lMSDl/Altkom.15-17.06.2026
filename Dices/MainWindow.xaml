<Window x:Class="Dices.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Dices"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Dices.Properties"
        Title="MainWindow"
        Width="800"
        Height="450"
        mc:Ignorable="d">
    <DockPanel>
        <Button Width="32"
                Click="Button_Remove"
                Content="-"
                DockPanel.Dock="Left"
                FontSize="32" />
        <Button Width="32"
                Click="Button_Add"
                Content="+"
                DockPanel.Dock="Right"
                FontSize="32" />
        <Button Content="{x:Static properties:Resources.Roll}"
                DockPanel.Dock="Bottom"
                Click="Button_Roll"
                FontSize="32" />

        <ItemsControl ItemsSource="{Binding Dices}" Padding="5">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Image Source="/Images/kostkapusta.png" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>
</Window>
