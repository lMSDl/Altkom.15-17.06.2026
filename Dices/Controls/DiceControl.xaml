<UserControl x:Class="Dices.Controls.DiceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dices.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Image>
        <Image.Style>
            <Style TargetType="Image">
                <Setter Property="Source" Value="/Images/kostkapusta.png" />
                <!--  StyleTriggers kolekcja wyzwalaczy  -->
                <Style.Triggers>
                    <!--  DataTrigger - wyzwalacz danych, który zmienia właściwość w zależności od wartości powiązanej właściwości  -->
                    <!--  Binding - powiązanie do właściwości Value w klasie Dice  -->
                    <!--  Value - wartość, która wyzwala zmianę  -->
                    <!--  Setter - ustawia wartość właściwości Source na odpowiedni obrazek  -->
                    <DataTrigger Binding="{Binding Value}"
                                 Value="1">
                        <Setter Property="Source" Value="/Images/kostka1.png" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Value}"
                                 Value="2">
                        <Setter Property="Source" Value="/Images/kostka2.png" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Value}"
                                 Value="3">
                        <Setter Property="Source" Value="/Images/kostka3.png" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Value}"
                                 Value="4">
                        <Setter Property="Source" Value="/Images/kostka4.png" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Value}"
                                 Value="5">
                        <Setter Property="Source" Value="/Images/kostka5.png" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Value}"
                                 Value="6">
                        <Setter Property="Source" Value="/Images/kostka6.png" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLocked}"
                                 Value="True">
                        <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Image.Style>

    </Image>
</UserControl>
