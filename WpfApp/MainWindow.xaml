<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WpfApp"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="MainWindow"
        Width="800"
        Height="450"
        mc:Ignorable="d">

    <!--<Button Background="Blue" Content="Click me!" Foreground="White" />-->
    <!--<Button Background="Green" >
        <Button.Content>Click me!</Button.Content>
        <Button.Foreground>White</Button.Foreground>
    </Button>-->

    <!--  kontrolki i layouty mają właściwości "domyślne", do których nazw nie musimy się odwoływać przy zagnieżdzaniu  -->
    <!--<Window.Content>-->
    <!--<Button Background="Blue" Foreground="White" > Hello! </Button>-->
    <!--</Window.Content>-->


    <!--  DockPanel - layout pozwalający na dokowanie elementów do jednej z krawędzi  -->
    <!--  ostatni element w DockPanel zajmuje całą resztę wolnego miejsca  -->
    <DockPanel>

        <!--  kolejność elementów w DockPanel ma znaczenie, ponieważ są one dokowane do krawędzi w kolejności ich deklaracji  -->
        <Button DockPanel.Dock="Bottom">DockButton 1</Button>
        <Button DockPanel.Dock="Top">DockButton 2</Button>
        <Button DockPanel.Dock="Left">DockButton 3</Button>
        <Button DockPanel.Dock="Right">DockButton 4</Button>
        <Button DockPanel.Dock="Bottom">DockButton 5</Button>


        <!--  Grid pozwalający na podział widoku na kolumny i wiersze  -->
        <!-- RowDefinition posiada nowy sposób zapisu bez <RowDefinitions> -->
        <Grid RowDefinitions="2*,auto,*,230">
            <!--  1 kolumna o szerokości 150, 2 kolumna o szerokości 1*, 3 kolumna o szerokości auto, 4 kolumna o szerokości 3*  -->
            <Grid.ColumnDefinitions>
                <!--  150 oznacza, że szerokość kolumny wynosi 150 pikseli  -->
                <ColumnDefinition Width="150" />
                <!--  * oznacza, że szerokość kolumny jest proporcjonalna pozostałego wolnego miejsca w widoku  -->
                <ColumnDefinition Width="*" />
                <!--  auto oznacza, że szerokość kolumny jest równa szerokości zawartości  -->
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!--  HorizontalContentAlignment - poziome wyjustowanie wewnątrz kontrolki  -->
            <Button HorizontalContentAlignment="Right"
                    Background="Aqua">
                Button 1
            </Button>
            <!--  HorizontalAlignment - poziome wyjustowanie kontrolki wewnątrz jej kontenera  -->
            <Button Grid.Column="0"
                    Width="50"
                    HorizontalAlignment="Left"
                    VerticalContentAlignment="Top">
                Button 2
            </Button>


            <!--  Grid.Row / Grid.Column - określa w którym wierszu i kolumnie znajduje się kontrolka  -->
            <Button Grid.Column="1">Button 3</Button>
            <Button Grid.Column="3">Button 5</Button>

            <Button Grid.Column="2">Button 4</Button>

            <!--  Grid.RowSpan / Grid.ColumnSpan - określa ile wierszy zajmuje kontrolka  -->
            <Button Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2">
                Button 6
            </Button>
            <!--  Jeśli elementy na siebie nachodzą, to w przypadku grid kolejność implementacji odpowiada kolejności wyświetlania, czyli elementy zdefiniowane później są wyświetlane na wierzchu  -->
            <Button Grid.Row="2"
                    Grid.RowSpan="2"
                    Grid.Column="2"
                    Grid.ColumnSpan="2">
                Button 8
            </Button>
            <Button Grid.Row="1"
                    Grid.RowSpan="2"
                    Grid.Column="2">
                Button 7
            </Button>
        </Grid>

        <!--  ScrollViewer - layout pozwalający na dodanie paska przewijania do zawartości  -->
        <!--  VerticalScrollBarVisibility - określa widoczność paska przewijania w pionie. Auto - pasek przewijania jest widoczny tylko wtedy, gdy zawartość jest większa niż obszar widoczny  -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto">
            <!--  StackPanel - layout pozwalający na ustawienie elementów jeden pod drugim (domyślnie: Orientation="Vertical")  -->
            <!--  Orientation - określa kierunek ułożenia elementów w StackPanel  -->
            <StackPanel HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button>StackButton 1</Button>
                <Button>StackButton 2</Button>
                <Button FontSize="20">StackButton 3</Button>
                <Button>StackButton 4</Button>
                <Button>StackButton 5</Button>
            </StackPanel>
        </ScrollViewer>

        <!--  WrapPanel - layout pozwalający na ustawienie elementów jeden obok drugiego (domyślnie: Orientation="Horizontal")  -->
        <!--  elementy, które nie mieszczą się w jednej linii, są przesuwane do kolejnej linii  -->
        <!--  Orientation - określa kierunek ułożenia elementów w WrapPanel  -->
        <WrapPanel Orientation="Vertical">
            <!--  Padding - określa odstęp wewnętrzny od krawędzi kontrolki do zawartości  -->
            <Button Padding="15,10">WrapButton 1</Button>
            <!--  Margin - określa odstęp zewnętrzny od krawędzi kontrolki  -->
            <!--  wartość jedna oznacza odstęp od wszystkich krawędzi, wartość dwóch oznacza odstęp od krawędzi poziomych i pionowych  -->
            <Button Margin="10">WrapButton 2</Button>
            <Button FontSize="20">WrapButton 3</Button>
            <Button Margin="5,10">WrapButton 4</Button>
            <Button Margin="5,10,15,20">WrapButton 5</Button>
            <Button>WrapButton 6</Button>
        </WrapPanel>

        <!--  Canvas - layout pozwalający na ustawienie elementów w dowolnym miejscu  -->
        <!--  Canvas może umieszczać elementy poza swoimi granicami  -->
        <Canvas Width="50"
                Height="50"
                Background="Beige">
            <Button>CanvasButton 1</Button>
            <!--  Canvas.Left / Canvas.Top - określa odległość od lewej / górnej krawędzi  -->
            <Button Canvas.Left="-350"
                    Canvas.Top="50">
                CanvasButton 2
            </Button>
            <!--  Canvas.Right / Canvas.Bottom - określa odległość od prawej / dolnej krawędzi  -->
            <Button Canvas.Right="150"
                    Canvas.Bottom="-150">
                CanvasButton 2
            </Button>
        </Canvas>

        <!--  UniformGrid - layout pozwalający na ustawienie elementów w równych odstępach w formie siatki  -->
        <!--  Columns - określa liczbę kolumn w siatce  -->
        <!--  Rows - określa liczbę wierszy w siatce (wartość 0 oznacza automatyczną ilość)  -->
        <!--  Jeśli elementów jest więcej niż określona liczba wierszy, to mogą być one nie wyświetlone  -->
        <UniformGrid Columns="4"
                     Rows="0">
            <Button>UniformGridButton 1</Button>
            <Button>UniformGridButton 2</Button>
            <Button>UniformGridButton 3</Button>
            <Button>UniformGridButton 4</Button>
            <Button>UniformGridButton 5</Button>
            <Button>UniformGridButton 6</Button>
            <Button>UniformGridButton 7</Button>
            <Button>UniformGridButton 8</Button>
            <Button>UniformGridButton 9</Button>
            <Button Content="UniformGridButton 10">
                <!--  ToolTip - tekst wyświetlany po najechaniu kursorem na kontrolkę  -->
                <!--<Button.ToolTip>ala ma kota</Button.ToolTip>-->
                <Button.ToolTip>
                    <Viewbox Width="500"
                             Height="500">
                        <Button>UniformGridButton 10</Button>
                    </Viewbox>
                </Button.ToolTip>

            </Button>
        </UniformGrid>

        <!--  Viewbox - layout pozwalający na skalowanie zawartości wewnątrz  -->
        <Viewbox>
            <Button>ViewboxButton</Button>
        </Viewbox>

    </DockPanel>

</Window>
