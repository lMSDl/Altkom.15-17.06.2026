<Window x:Class="WpfApp.ContentControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WpfApp"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Models;assembly=Models"
        Title="ContentControlWindow"
        Width="800"
        Height="450"
        mc:Ignorable="d">

    <!--  TabControl - kontrolka do wyświetlania zakładek  -->
    <TabControl BorderBrush="DarkBlue"
                BorderThickness="3"
                SelectedIndex="0"
                TabStripPlacement="Left">
        <TabItem>
            <TabItem.Header>
                <StackPanel Margin="0"
                            Orientation="Horizontal">
                    <Label Margin="0"
                           Padding="0"
                           Content="ItemsControl" />
                    <Rectangle Width="10"
                               Height="10"
                               Margin="5,0,0,0"
                               Fill="Red" />
                </StackPanel>
            </TabItem.Header>

            <!--  ScrollViewer jest potrzebny, aby kontrolka ItemsControl mogła przewijać zawartość  -->
            <ScrollViewer>
                <!--  ItemsControl - podstawowa kontrolka do wyświetlania listy elementów, nie obsługuje interakcji z użytkownikiem  -->
                <!--  ItemsSource - źródło danych, które będzie wyświetlane w kontrolce  -->
                <!--  Binding - wiązanie danych, pozwala na powiązanie źródła danych z kontrolką  -->
                <!--  Path=Products - ścieżka do właściwości w źródle danych, która będzie wyświetlana w kontrolce  -->
                <!--  DataContext (ustawiony w code behind na okno  - this) - kontekst danych, pozwala na powiązanie źródła danych z kontrolką  -->
                <ItemsControl ItemsSource="{Binding Products}">
                    <!--  ItemTemplate - szablon elementu, który będzie wyświetlany w kontrolce  -->
                    <ItemsControl.ItemTemplate>
                        <!--  DataTemplate przełącza kontekst danych (DataContext) na elementy w szablonie  -->
                        <!--  Path jest w domyślnym kontekście danych, czyli w kontekście elementu (nie trzeba do pisać jawnie)  -->
                        <DataTemplate DataType="{x:Type models:Product}">
                            <Grid ColumnDefinitions="*,2*,.5*,*">
                                <Label Grid.Column="0"
                                       Content="{Binding Name}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />
                                <Label Grid.Column="2"
                                       HorizontalContentAlignment="Right"
                                       Content="{Binding Price}" />
                                <Label Grid.Column="3"
                                       HorizontalContentAlignment="Right"
                                       Content="{Binding ExpirationDate}" />
                            </Grid>
                            <!--<StackPanel Orientation="Vertical">
                                <Label  Content="{Binding Name}"/>
                                <Label  Content="{Binding Price}" HorizontalContentAlignment="Right"/>
                                <Label  Content="{Binding ExpirationDate}" HorizontalContentAlignment="Right"/>
                            </StackPanel>-->
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <!--  ItemsPanel - panel, w którym będą wyświetlane elementy  -->
                    <!--  jeśli nie zmodyfikujemy to domyślnie jest to StackPanel, ale możemy zmienić np. na UniformGrid  -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                            <!--<WrapPanel />-->
                            <!--<UniformGrid/>-->
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

        </TabItem>
        <TabItem Header="ListBox">
            <!--  ListBox - kontrolka do wyświetlania listy elementów, obsługuje interakcję z użytkownikiem, posiada wbudowany mechanizm przewijania  -->
            <!--  SelectionMode - tryb zaznaczania elementów, może być Single (pojedynczy), Multiple (wielokrotny) lub Extended (rozszerzony)  -->
            <!--  SelectedItem - zaznaczony element, można powiązać z właściwością w kontekście danych  -->
            <ListBox ItemsSource="{Binding Products}"
                     SelectedItem="{Binding SelectedProduct}"
                     SelectionMode="Extended">
                <ListBox.ItemTemplate>
                    <!--  DataType - typ danych, który będzie wyświetlany w kontrolce, pozwala na użycie szablonu tylko dla tego typu danych  -->
                    <DataTemplate DataType="models:Product">
                        <Grid ColumnDefinitions="auto,*"
                              RowDefinitions="auto,auto,auto,auto">
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Content="Nazwa:" />
                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Content="{Binding Name}" />

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Content="Opis:" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding Description}"
                                       TextWrapping="Wrap" />

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Content="Cena:" />
                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Content="{Binding Price}" />

                            <Label Grid.Row="3"
                                   Grid.Column="0"
                                   Content="Data przydatności:" />
                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Content="{Binding ExpirationDate}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

        </TabItem>
        <TabItem Header="ListView">
            <!--  ListView - kontrolka do wyświetlania listy elementów, obsługuje interakcję z użytkownikiem, posiada wbudowany mechanizm przewijania  -->
            <!--  dodaje możliwość wyświetlania kolumn  -->
            <ListView ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}">

                <!--  jeśli nie użjemy View, to ListView będzie wyświetlał elementy tak samo jak ListBox, czyli używając ItemTemplate  -->
                <!--<ListView.ItemTemplate>
                    <DataTemplate>
                        <Label Content="{Binding}" />
                    </DataTemplate>
                </ListView.ItemTemplate>-->


                <!--  View - widok, który będzie wyświetlany w kontrolce  -->
                <ListView.View>
                    <!--  GridView - widok dla ListView, pozwala na wyświetlanie danych w formie tabeli  -->
                    <GridView AllowsColumnReorder="False">

                        <!--  GridViewColumnHeader - szablon nagłówka kolumny, który będzie wyświetlany w kontrolce  -->
                        <GridView.ColumnHeaderTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="{Binding}" />
                                    <Rectangle Width="10"
                                               Height="10"
                                               Margin="5,0,0,0"
                                               Fill="Red" />
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ColumnHeaderTemplate>

                        <!--  GridViewColumn - kolumna, która będzie wyświetlana w kontrolce  -->
                        <!--  DisplayMemberBinding - wiązanie danych, pozwala na powiązanie źródła danych z kontrolką  -->
                        <!--  Header - nagłówek kolumny, może być tekstem lub innym elementem  -->
                        <GridViewColumn DisplayMemberBinding="{Binding Name}"
                                        Header="Nazwa" />
                        <GridViewColumn DisplayMemberBinding="{Binding Description}"
                                        Header="Opis" />
                        <GridViewColumn DisplayMemberBinding="{Binding Price}"
                                        Header="Cena" />
                        <GridViewColumn DisplayMemberBinding="{Binding ExpirationDate}"
                                        Header="Data przydatności" />
                    </GridView>
                </ListView.View>
            </ListView>
        </TabItem>
        <TabItem Header="DataGrid">

            <!--  DataGrid - kontrolka do wyświetlania tabeli z elementami, obsługuje interakcję z użytkownikiem, posiada wbudowany mechanizm przewijania i auto generacja kolumn  -->
            <!--  AutoGenerateColumns - automatyczne generowanie kolumn na podstawie właściwości w źródle danych  -->
            <DataGrid AutoGenerateColumns="False"
                      CanUserAddRows="True"
                      CanUserDeleteRows="True"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      Sorting="DataGrid_Sorting">

                <!--  DataGrid.Columns - kolumny, które będą wyświetlane w kontrolce  -->
                <DataGrid.Columns>
                    <!--  DataGridTextColumn - kolumna tekstowa, która będzie wyświetlana w kontrolce  -->
                    <!--  DataGridCheckBoxColumn - kolumna z polem wyboru, która będzie wyświetlana w kontrolce  -->
                    <DataGridCheckBoxColumn Binding="{Binding IsDamaged}"
                                            Header="Uszkodzony" />
                    <DataGridTextColumn Binding="{Binding Name}"
                                        Header="Nazwa" />
                    <DataGridTextColumn Binding="{Binding Description}"
                                        Header="Opis" />
                    <DataGridTextColumn Binding="{Binding Price}"
                                        Header="Cena" />
                    <DataGridTextColumn Binding="{Binding ExpirationDate}"
                                        Header="Data przydatności" />
                </DataGrid.Columns>
            </DataGrid>

        </TabItem>
    </TabControl>
</Window>
