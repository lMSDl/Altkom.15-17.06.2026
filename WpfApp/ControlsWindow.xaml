<Window x:Class="WpfApp.ControlsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WpfApp"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="ControlsWindow"
        Width="800"
        Height="450"
        mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel>
            <!--  Label - kontrolka wyświetlająca tekst w jednej linii  -->
            <Label FontSize="24"
                   FontStyle="Italic"
                   FontWeight="Bold">
                Ala ma
                \n kota
            </Label>
            <Label Content="i dwa psy" />

            <!--  TextBlock - kontrolka wyświetlająca tekst w wielu liniach, posiada większe możliwości formatowania niż Label  -->
            <TextBlock FontSize="24"
                       FontStyle="Oblique"
                       FontWeight="Heavy"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap">
                Ala ma<LineBreak />
                <Bold>
                    <Underline>kota \n</Underline>
                </Bold>
                <LineBreak />
                <Hyperlink NavigateUri="https://www.altkom.pl"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    Altkom
                </Hyperlink>
                Bardzo długi tekst, który nie mieści się w kontrolce i zostanie obcięty z użyciem wielokropka na końcu. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</TextBlock>

            <!--  TextBox - kontrolka do wprowadzania tekstu  -->
            <!--  AcceptsReturn - czy akceptuje Enter jako nową linię  -->
            <!--  AcceptsTab - czy akceptuje Tab jako wcięcie  -->
            <!--  SpellCheck.IsEnabled - czy włączyć sprawdzanie pisowni  -->
            <TextBox AcceptsReturn="True"
                     AcceptsTab="True"
                     SpellCheck.IsEnabled="True"
                     Text="..."
                     TextWrapping="Wrap"
                     ToolTip="Napisz coś!" />

            <!--  PasswordBox - kontrolka do wprowadzania hasła  -->
            <!--  x:Name - nazwa kontrolki, która pozwala na odwołanie się do niej w kodzie  -->
            <!--  x: rozszerzenie XAML, pozwala na tworzenie obiektów w XAML, kóre są dostępne w kodzie (code behind)  -->
            <PasswordBox x:Name="pass"
                         Password="alamakota"
                         PasswordChar="*" />

            <!--  CheckBox - kontrolka do zaznaczania jednej lub wielu opcji  -->
            <!--  IsThreeState - czy ma trzy stany: zaznaczony, niezaznaczony, nieokreślony  -->
            <CheckBox Content="Opcja 1" />
            <CheckBox Content="Opcja 2"
                      IsEnabled="False" />
            <CheckBox Content="Opcja 3"
                      IsChecked="True" />
            <CheckBox Content="Wszystkie"
                      IsThreeState="True" />


            <!--  RadioButton - kontrolka do zaznaczania jednej opcji z wielu  -->
            <Label>Question 1</Label>
            <RadioButton>Option 1</RadioButton>
            <RadioButton>Option 2</RadioButton>
            <RadioButton>Option 3</RadioButton>


            <!--  GroupName - nazwa grupy, do której należy RadioButton  -->
            <Label>Question 2</Label>
            <RadioButton GroupName="q2">Option 1</RadioButton>
            <RadioButton GroupName="q2">Option 2</RadioButton>
            <RadioButton GroupName="q2">
                <StackPanel Orientation="Horizontal">
                    <Label VerticalContentAlignment="Center">Option 3</Label>
                    <Image Width="32"
                           Height="32"
                           Source="Images/question_mark.jpg" />
                </StackPanel>
            </RadioButton>

            <Button>
                <StackPanel Orientation="Horizontal">
                    <Label VerticalContentAlignment="Center">Coś</Label>
                    <Image Width="32"
                           Height="32"
                           Source="Images/question_mark.jpg" >
                        <Image.LayoutTransform>
                            <RotateTransform Angle="{Binding ElementName=MySlider, Path=Value}" />
                        </Image.LayoutTransform>
                    </Image>
                </StackPanel>
            </Button>

            <!--  Slider - kontrolka do wybierania wartości z zakresu  -->
            <!--  AutoToolTipPlacement - położenie podpowiedzi wartości  -->
            <!--  Foreground - kolor tekstu  -->
            <!--  IsSnapToTickEnabled - czy przesuwanie suwaka ma być ograniczone do wartości z Tick  -->
            <!--  Maximum - maksymalna wartość  -->
            <!--  Minimum - minimalna wartość  -->
            <!--  TickFrequency - odstęp między wartościami  -->
            <!--  TickPlacement - położenie znaczników  -->
            <Slider x:Name="MySlider"
                    Foreground="Black"
                    IsSnapToTickEnabled="True"
                    Maximum="100"
                    Minimum="25"
                    TickFrequency="5"
                    TickPlacement="Both"
                    Value="50"
                    AutoToolTipPlacement="TopLeft"/>
            
            <!--  ProgressBar - kontrolka do wyświetlania postępu  -->
            <!--  Maximum - maksymalna wartość  -->
            <!--  Value - wartość  -->
            <!--  IsIndeterminate - czy ma być wyświetlany pasek postępu nieokreślony  -->
            <ProgressBar Height="32" Value="{Binding ElementName=MySlider, Path=Value}"/>
            <ProgressBar Height="32" IsIndeterminate="True"/>

        </StackPanel>
    </ScrollViewer>
</Window>
