<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Style - styl, który można zastosować do kontrolki  -->
    <!--  TargetType - typ kontrolki, do której styl będzie zastosowany  -->
    <Style TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="Blue" />
    </Style>

    <!--  x:Key - klucz, pod którym styl będzie dostępny, jeśli nie ma klucza to styl automatycznie zastosowany będzie do TargetType  -->
    <!--  BasedOn - pozwala na dziedziczenie stylu z innego stylu  -->
    <Style x:Key="RedBoldStyle"
           BasedOn="{StaticResource RedItalicStyle}"
           TargetType="Label">
        <!--  Setter - ustawia właściwość kontrolki na określoną wartość  -->
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="RedRectangleStyle"
           TargetType="Rectangle">
        <Setter Property="Fill" Value="Red" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Margin" Value="5,0,0,0" />
    </Style>

</ResourceDictionary>