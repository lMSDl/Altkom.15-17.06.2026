<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  DataType - typ danych, który będzie wyświetlany w kontrolce, pozwala na użycie szablonu tylko dla tego typu danych  -->
    <DataTemplate x:Key="ProductTemplate"
                  DataType="models:Product">
        <Grid ColumnDefinitions="auto,*"
              RowDefinitions="auto,auto,auto,auto">
            <Label Grid.Row="0"
                   Grid.Column="0"
                   Content="Nazwa:" />
            <Label Grid.Row="0"
                   Grid.Column="1"
                   Content="{Binding Name}" />

            <Label Grid.Row="1"
                   Grid.Column="0"
                   Content="Opis:" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding Description}"
                       TextWrapping="Wrap" />

            <Label Grid.Row="2"
                   Grid.Column="0"
                   Content="Cena:" />
            <Label Grid.Row="2"
                   Grid.Column="1"
                   Content="{Binding Price}" />

            <Label Grid.Row="3"
                   Grid.Column="0"
                   Content="Data przydatności:" />
            <Label Grid.Row="3"
                   Grid.Column="1"
                   Content="{Binding ExpirationDate}" />
        </Grid>
    </DataTemplate>
</ResourceDictionary>