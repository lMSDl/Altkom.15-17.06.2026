<Page x:Class="Warehouse.Views.ProductsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:convertersToolkit="clr-namespace:Toolkit.MVVM.Converters;assembly=Toolkit.MVVM"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Warehouse.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:properties="clr-namespace:Warehouse.Properties"
      xmlns:vm="clr-namespace:Warehouse.ViewModels"
      Title="ProductsView"
      d:DesignHeight="450"
      d:DesignWidth="800"
      mc:Ignorable="d">

    <Page.DataContext>
        <vm:ProductsViewModel />
    </Page.DataContext>

    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction Command="{Binding OnLoadedCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>

    <Grid>
        <DockPanel>
            <UniformGrid DockPanel.Dock="Bottom"
                         Rows="1">
                <Button Command="{Binding AddCommand}"
                        Content="{x:Static properties:Resources.Add}"
                        CommandParameter="{x:Type local:ProductView}" />
                <Button Command="{Binding EditCommand}"
                        Content="{x:Static properties:Resources.Edit}"
                        CommandParameter="{x:Type local:ProductView}" />
                <Button Command="{Binding RemoveCommand}"
                        Content="{x:Static properties:Resources.Delete}" />
            </UniformGrid>

            <DataGrid AutoGenerateColumns="False"
                      IsEnabled="{Binding IsLoading, Converter={convertersToolkit:BoolNegationConverter}}"
                      IsReadOnly="True"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}">

                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsDamaged}"
                                            Header="{x:Static properties:Resources.Damaged}" />
                    <DataGridTextColumn Binding="{Binding Name}"
                                        Header="{x:Static properties:Resources.Name}" />
                    <DataGridTextColumn Binding="{Binding Description}"
                                        Header="{x:Static properties:Resources.Description}" />
                    <DataGridTextColumn Binding="{Binding Price}"
                                        Header="{x:Static properties:Resources.Price}" />
                    <DataGridTextColumn Binding="{Binding ExpirationDate}"
                                        Header="{x:Static properties:Resources.ExpirationDate}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <ProgressBar Foreground="Gray"
                     IsIndeterminate="True"
                     Opacity="0.5"
                     Visibility="{Binding IsLoading, Converter={convertersToolkit:BoolToVisibilityConverter}}" />
    </Grid>
</Page>
