<Page x:Class="ArchitecturalPatterns.Views.MvvmView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ArchitecturalPatterns.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:ArchitecturalPatterns.ViewModels"
      Title="MvvmView"
      d:DesignHeight="450"
      d:DesignWidth="800"
      mc:Ignorable="d">

    <!--  EventToCommand - pozwala powiązać dowolne zdarzenie strony z ICommand w ViewModelu  -->
    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction Command="{Binding OnPageLoadedCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>

    <Page.DataContext>
        <vm:ViewModel />
    </Page.DataContext>

    <StackPanel>
        <TextBox Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}" />
        <Label Content="{Binding Model.Value}" />
        <Button Command="{Binding SaveCommand}"
                Content="Save" />
        <Button Command="{Binding LoadCommand}"
                Content="Load" />
    </StackPanel>
</Page>
